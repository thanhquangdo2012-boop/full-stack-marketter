# Copy file này thành .env.local (không commit .env.local lên git — xem RULE-01)

# ============================================================
# Supabase — https://app.supabase.com/project/_/settings/api
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# CHỈ dùng ở server (API routes), KHÔNG BAO GIỜ để lộ ra bundle frontend — RULE-01/RULE-03
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Upstash Redis (rate limiting) — https://console.upstash.com
# ============================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# Auth — bí mật ký JWT/session cookie cho hệ thống đăng nhập tự viết
# Tạo bằng: openssl rand -base64 32
# ============================================================
AUTH_SECRET=

# ============================================================
# Admin — tài khoản duy nhất truy cập /admin (Đỗ Thanh Quang)
# ⚠️ ADMIN_PASSWORD_HASH chứa dấu $ (bcrypt hash dạng $2a$12$...) — file
# .env.local được Next.js load với cơ chế expand kiểu shell ($VAR bị hiểu
# là biến môi trường khác). PHẢI escape mỗi dấu $ thành \$, nếu không phần
# đầu hash sẽ bị cắt mất và đăng nhập admin luôn báo sai mật khẩu dù đúng.
# Ví dụ đúng: ADMIN_PASSWORD_HASH=\$2a\$12\$abc123...
# (Chỉ ảnh hưởng .env.local ở máy dev — biến môi trường khai báo trực tiếp
# trên Vercel dashboard KHÔNG bị lỗi này, không cần escape ở đó.)
# ============================================================
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# ============================================================
# Resend — https://resend.com/api-keys
# Báo ADMIN qua email khi có đơn đăng ký mới (lib/email.ts). Chưa xác minh
# domain riêng => CHỈ gửi được tới đúng email chủ tài khoản Resend (đặt
# trùng ADMIN_EMAIL ở trên). Bỏ trống thì tính năng này tự tắt, không lỗi.
# ============================================================
RESEND_API_KEY=

# ============================================================
# SePay — https://developer.sepay.vn (webhook tự động xác nhận thanh toán)
# Tạo chuỗi ngẫu nhiên: openssl rand -hex 32
# Dán CÙNG giá trị này vào cấu hình webhook trên dashboard SePay (kiểu xác
# thực HMAC-SHA256, không dùng "None"/"API Key" đơn giản — xem README.md
# phần SePay). Webhook URL: https://<domain-that-của-bạn>/api/webhooks/sepay
# Bỏ trống thì webhook luôn từ chối request (an toàn — không tự mở khoá gì
# khi chưa cấu hình xong), vẫn xác nhận đơn tay ở /admin/orders bình thường.
# ============================================================
SEPAY_WEBHOOK_SECRET=

# ============================================================
# Thông tin chuyển khoản hiển thị ở trang /checkout
# CẦN ĐIỀN THẬT trước khi cho khách thanh toán — xem project-brief.md
# ============================================================
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_NAME=

# Kênh liên hệ/giao hàng (Zalo) — xem project-brief.md
NEXT_PUBLIC_ZALO_CONTACT=
